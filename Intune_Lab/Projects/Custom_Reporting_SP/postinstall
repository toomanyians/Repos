#!/bin/bash
set -euo pipefail
###############################################
# Configuration
###############################################
PFX_FILE="$INSTALL_DIR/<PFX FILENAME>"
CERT_THUMBPRINT="<THUMBPRINT>"
PFX_PASSWORD="<PFX PASSWORD>"
#
INSTALL_DIR="/Library/Application Support/MyCompany"
KEYCHAIN="/Library/Keychains/System.keychain"
CERT_THUMBPRINT=$(echo "$CERT_THUMBPRINT" | tr '[:upper:]' '[:lower:]')
###############################################
# Functions
###############################################
cleanup()
{
    echo "Cleaning up temporary files..."
    rm -f "$PFX_FILE" || true
}
error_exit()
{
    echo "ERROR: $1"
    exit 1
}
trap cleanup EXIT
###############################################
# Validate files exist
###############################################
echo "Checking package contents..."
[[ -f "$PFX_FILE" ]]  || error_exit "PFX file not found"
###############################################
# Import PFX
###############################################
echo "Importing PFX..."
security import "$PFX_FILE" -k "$KEYCHAIN" -P "$PFX_PASSWORD" -A || error_exit "PFX import failed"
###############################################
# Verify identity
###############################################
echo "Verifying identity..."
IDENTITY_FOUND=$(security find-identity -v "$KEYCHAIN" | tr -d ' ' | tr '[:upper:]' '[:lower:]' | grep "$CERT_THUMBPRINT" || true)
if [[ -z "$IDENTITY_FOUND" ]]; then
    error_exit "Certificate/private key identity not found"
fi
echo "Identity verified."
###############################################
# Display installed identity
###############################################
echo
echo "Installed identities:"
security find-identity -v "$KEYCHAIN"
echo
echo "Certificate deployment completed successfully."
exit 0